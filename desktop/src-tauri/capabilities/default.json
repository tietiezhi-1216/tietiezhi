{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口与胶囊窗口的默认能力",
  "windows": ["main", "capsule"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-theme",
    "updater:default",
    "process:default",
    "dialog:default"
  ]
}
